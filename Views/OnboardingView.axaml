<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RepoSweep.ViewModels"
             x:Class="RepoSweep.Views.OnboardingView"
             x:DataType="vm:MainViewModel">
    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480">
            <StackPanel Spacing="20" HorizontalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="16"
                        Background="{DynamicResource CardBackgroundColor}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        HorizontalAlignment="Center">
                    <LucideIcon Kind="Sparkles" Size="28"
                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Add a workspace"
                               FontSize="24" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Pick a folder that contains your projects. RepoSweep will scan it and find cleanup targets."
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Opacity="0.7"
                               MaxWidth="400" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Classes="Primary" Padding="16,10"
                            Command="{Binding AutoDetectCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <LucideIcon Kind="Zap" Size="16" />
                            <TextBlock Text="Auto-detect" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="Outline" Padding="16,10"
                            Command="{Binding AddWorkspaceCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <LucideIcon Kind="Folder" Size="16" />
                            <TextBlock Text="Browse..." VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
