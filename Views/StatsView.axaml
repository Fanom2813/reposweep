<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RepoSweep.ViewModels"
             xmlns:cv="clr-namespace:RepoSweep.Converters"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             x:Class="RepoSweep.Views.StatsView"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel Spacing="2">
                <TextBlock Text="Statistics" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Workspace analytics and insights" FontSize="12" Opacity="0.65" />
            </StackPanel>
        </Border>

        <!-- Empty state -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="10"
                    IsVisible="{Binding !Stats.HasData}">
            <LucideIcon Kind="ChartBar" Size="32" Opacity="0.4"
                        HorizontalAlignment="Center" />
            <TextBlock Text="No data yet" FontSize="16" FontWeight="Medium" HorizontalAlignment="Center" />
            <TextBlock Text="Scan a workspace to see statistics." Opacity="0.6" HorizontalAlignment="Center" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" IsVisible="{Binding Stats.HasData}">
            <StackPanel Margin="20" Spacing="24">

                <!-- Summary cards -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Classes="stat"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="10" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Stats.CurrentlyReclaimableLabel}"
                                       FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Reclaimable" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="10" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Stats.TotalProjectsScanned}"
                                       FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Projects" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="10" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Stats.TotalReclaimedLabel}"
                                       FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Total Reclaimed" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="10" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Stats.TotalProjectsCleaned}"
                                       FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Cleanups" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Breakdown by type -->
                <StackPanel Spacing="12">
                    <TextBlock Text="BY PROJECT TYPE" FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                    <ItemsControl ItemsSource="{Binding Stats.TypeBreakdown}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:StatsTypeBreakdown">
                                <Grid ColumnDefinitions="140,*,80,90" Margin="0,4">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <svg:Svg Width="14" Height="14"
                                                 Path="{Binding Devicon, Converter={x:Static cv:DeviconUriConverter.Instance}}" />
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{DynamicResource GhostColor}"
                                            Height="8" CornerRadius="4"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <Border HorizontalAlignment="Left"
                                                Height="8"
                                                CornerRadius="4"
                                                Background="{DynamicResource Accent}"
                                                Width="{Binding BarPercent}" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding CountLabel}"
                                               FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding ReclaimableLabel}"
                                               FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Top consumers -->
                <StackPanel Spacing="12">
                    <TextBlock Text="TOP SPACE CONSUMERS" FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                    <ItemsControl ItemsSource="{Binding Stats.LargestProjects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:StatsLargestProject">
                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                                        Padding="0,10">
                                    <Grid ColumnDefinitions="30,*,140,90" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" Text="{Binding Rank}"
                                                   FontSize="12" FontWeight="SemiBold" Opacity="0.55"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Path}" Classes="mono" FontSize="11" Opacity="0.55"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Classes="Badge"
                                                VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <svg:Svg Width="14" Height="14"
                                                         Path="{Binding Devicon, Converter={x:Static cv:DeviconUriConverter.Instance}}" />
                                                <TextBlock Text="{Binding Type}" FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding SizeLabel}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
